{
  "disableArtifact": true,
  "disableBundledSkills": true,
  "disableClaudeAiConnectors": true,
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "effortLevel": "medium",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "inputNeededNotifEnabled": true,
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(chmod +x *)",
      "Bash(git *)",
      "Bash(git:*)",
      "Bash(go build *)",
      "Bash(go get *)",
      "Bash(go mod *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(just *)",
      "Bash(just refs *)",
      "Bash(ls ~/.work-items/*)",
      "Bash(mkdir -p ~/.work-items/*)",
      "Bash(tmux show-*)",
      "Bash(tmux source-file *)",
      "Bash(zsh -cie \"nvm use \\\\$\\(cat .nvmrc\\) && npm *)",
      "Bash(zsh -cie \"nvm use \\\\$\\(cat .nvmrc\\) && npx *)",
      "Bash(zsh -cie \"nvm use \\\\$\\(cat .nvmrc\\) && yarn *)",
      "Bash(~/.bin/work-item-id)",
      "Read(~/.work-items/**)"
    ],
    "deny": [
      "AskUserQuestion",
      "Bash(git push *)",
      "Bash(git push:*)",
      "Bash(just install-*)",
      "CronCreate",
      "CronDelete",
      "CronList",
      "DesignSync",
      "EnterPlanMode",
      "ExitPlanMode",
      "NotebookEdit",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "ScheduleWakeup",
      "SendMessage"
    ]
  },
  "spinnerTipsEnabled": false,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "theme": "auto"
}
