#!/usr/bin/env sh
# Sends a message to Telegram, formatting Markdown-ish input for chat display.
message="$*"

if [ -z "$message" ]; then
  echo "Error: Message cannot be empty."
  exit 1
fi

parsed=$(echo "$message" | awk '
function indent(level) {
  return sprintf("%*s", level * 2, "")
}

{
  line = $0

  # --- HEADERS ---
  if (match(line, /^#{1,6}[[:space:]]+/)) {
    level = RLENGTH - 1
    sub(/^#{1,6}[[:space:]]+/, "", line)

    if (level == 1) {
      print "🔥 *" toupper(line) "*"
      print "────────────"
    }
    else if (level == 2) {
      print ""
      print "👉 *" line "*"
    }
    else {
      print indent(level-1) "• *" line "*"
    }
  }

  # --- CHECKBOXES (with nesting support) ---
  else if (match(line, /^[[:space:]]*- \[[xX ]\]/)) {
    spaces = RLENGTH
    done = (line ~ /\[[xX]\]/) ? "✅" : "⬜"

    sub(/^[[:space:]]*- \[[xX ]\][[:space:]]*/, "", line)

    indent_level = int(spaces / 2)
    print indent(indent_level) done " " line
  }

  # --- NORMAL LISTS ---
  else if (match(line, /^[[:space:]]*[-*] /)) {
    sub(/^[[:space:]]*[-*] /, "", line)
    print "• " line
  }

  # --- EMPTY LINE ---
  else if (line ~ /^[[:space:]]*$/) {
    print ""
  }

  # --- DEFAULT ---
  else {
    print line
  }
}')

curl -s -X POST "https://api.telegram.org/bot${AI_AGENT_TELEGRAM_TOKEN}/sendMessage" \
  -d "chat_id=${AI_AGENT_TELEGRAM_CHAT_ID}" \
  --data-urlencode "text=$parsed" \
  -d "parse_mode=Markdown" > /dev/null

if [ $? -eq 0 ]; then
  echo "Sent to Telegram ✅"
else
  echo "Error sending message ❌"
fi
